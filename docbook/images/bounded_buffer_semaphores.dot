digraph bounded_buffer_semaphores {
  graph [
    label="Bounded Buffer (Producer–Consumer) with Semaphores",
    labelloc="t",
    fontsize=16,
    fontname="Helvetica",
    bgcolor="white",
    rankdir="TB",
    splines="polyline",
    nodesep=0.45,
    ranksep=0.65
  ];

  node [
    fontname="Helvetica",
    fontsize=11,
    color="#2b2b2b",
    shape="box",
    style="rounded",
    margin="0.18,0.10"
  ];

  edge [
    fontname="Helvetica",
    fontsize=10,
    color="#2b2b2b",
    arrowsize=0.8
  ];

  producer [label="Producer task\\nPutItem()"];
  buffer [label="Ring buffer\\nK slots\\n(buf[], putIdx, getIdx)"];
  consumer [label="Consumer task\\nGetItem()"];

  slotSema [
    label="slotSema\\nfree slots\\ninit=K, max=K"
  ];
  acquireSema [
    label="acquireSema\\nmutex\\ninit=1, max=1"
  ];
  itemSema [
    label="itemSema\\nitems\\ninit=0, max=K"
  ];

  { rank=same; producer; buffer; consumer; }
  { rank=same; slotSema; acquireSema; itemSema; }

  producer -> buffer [label="write item"];
  buffer -> consumer [label="read item"];

  producer -> slotSema [label="pend() before put"];
  consumer -> slotSema [label="post() after get"];

  consumer -> itemSema [label="pend() before get"];
  producer -> itemSema [label="post() after put"];

  producer -> acquireSema [style="dashed", label="pend()/post()\\ncritical section"];
  consumer -> acquireSema [style="dashed", label="pend()/post()\\ncritical section"];

  acquireSema -> buffer [style="dotted", arrowhead="none", label="guards buf[] + indices"];
  slotSema -> acquireSema [style="invis", weight=2];
  acquireSema -> itemSema [style="invis", weight=2];
}
